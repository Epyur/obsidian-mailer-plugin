{
  "name": "obsidian-mailer-plugin",
  "version": "1.0.0",
  "description": "Технический помощник TECHNONICOL для Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "watch": "node esbuild.config.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "builtin-modules": "^5.2.0",
    "esbuild": "^0.17.0",
    "obsidian": "latest",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "docx": "^9.7.1",
    "jszip": "^3.10.1"
  },
  "allowScripts": {
    "esbuild@0.17.19": true
  }
}
